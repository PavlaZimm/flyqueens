# OpenSky Network credentials — registrace zdarma na opensky-network.org
# S auth: polling každých 5s, bez auth: každých 10s
OPENSKY_USERNAME=your_username
OPENSKY_PASSWORD=your_password

# Supabase — pro budoucí auth a oblíbené lety (zatím nepotřeba)
# NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxx

# OpenWeatherMap — pro vrstvu počasí na mapě (zatím nepotřeba)
# NEXT_PUBLIC_OWM_KEY=your_key_here
